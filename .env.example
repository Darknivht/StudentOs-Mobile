# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# AI Provider (openai | gemini | custom)
EXPO_PUBLIC_AI_PROVIDER=gemini
EXPO_PUBLIC_AI_BASE_URL=
EXPO_PUBLIC_AI_API_KEY=your-ai-api-key
EXPO_PUBLIC_AI_MODEL=gemini-2.0-flash

# Payment Provider (paystack | flutterwave)
EXPO_PUBLIC_PAYMENT_PROVIDER=paystack
EXPO_PUBLIC_PAYMENT_PUBLIC_KEY=your-payment-public-key
